# BigQuery DDL Template Variables
# Used by deploy.sh (envsubst) to substitute project and dataset references
# in all .sql files before execution.
#
# Usage:
#   export $(grep -v '^#' variables.env | xargs)
#   envsubst < ddl/raw/tables/sales_retail.sql | bq query --use_legacy_sql=false
#
# Override any variable at deploy time:
#   PROJECT_US=my-project-123 ./deploy.sh

# US multi-region project (hosts raw, staging, retail datasets)
PROJECT_US=acme-analytics

# EU multi-region project (hosts regional_eu dataset for GDPR compliance)
PROJECT_EU=acme-analytics-eu

# Dataset names
DS_RAW=raw
DS_STAGING=staging
DS_RETAIL=retail
DS_REGIONAL=regional_eu

# Shared UDF dataset (referenced by views like vw_panel_continuity_score)
DS_UDFS=udfs
